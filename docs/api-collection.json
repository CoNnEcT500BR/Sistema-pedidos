{
  "info": {
    "name": "Sistema Pedidos API - Fase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection completa da Fase 2 cobrindo Auth, Menu, Combos, Orders, Addons e Swagger."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "menuItemId",
      "value": ""
    },
    {
      "key": "comboId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@sistema.local\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Sessao Atual",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Menu",
      "item": [
        {
          "name": "Listar Categorias",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            }
          }
        },
        {
          "name": "Listar Itens",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/menu",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu"
              ]
            }
          }
        },
        {
          "name": "Listar Itens por Categoria",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/menu?category={{categoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "{{categoryId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Detalhe de Item",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/menu/{{menuItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu",
                "{{menuItemId}}"
              ]
            }
          }
        },
        {
          "name": "Criar Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"name\": \"Item API Collection\",\n  \"description\": \"Criado pela collection da fase 2\",\n  \"price\": 18.9,\n  \"icon\": \"🍔\",\n  \"displayOrder\": 99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menu",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu"
              ]
            }
          }
        },
        {
          "name": "Atualizar Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Atualizado pela collection\",\n  \"price\": 21.5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menu/{{menuItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu",
                "{{menuItemId}}"
              ]
            }
          }
        },
        {
          "name": "Atualizar Disponibilidade do Item",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isAvailable\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menu/{{menuItemId}}/availability",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu",
                "{{menuItemId}}",
                "availability"
              ]
            }
          }
        },
        {
          "name": "Desativar Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/menu/{{menuItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu",
                "{{menuItemId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Combos",
      "item": [
        {
          "name": "Listar Combos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/combos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "combos"
              ]
            }
          }
        },
        {
          "name": "Detalhe de Combo",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/combos/{{comboId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "combos",
                "{{comboId}}"
              ]
            }
          }
        },
        {
          "name": "Criar Combo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Combo API Collection\",\n  \"description\": \"Combo criado via collection\",\n  \"price\": 34.9,\n  \"displayOrder\": 99,\n  \"comboItems\": [\n    {\n      \"menuItemId\": \"{{menuItemId}}\",\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/combos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "combos"
              ]
            }
          }
        },
        {
          "name": "Atualizar Combo",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Combo atualizado pela collection\",\n  \"price\": 39.9\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/combos/{{comboId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "combos",
                "{{comboId}}"
              ]
            }
          }
        },
        {
          "name": "Atualizar Disponibilidade do Combo",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isAvailable\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/combos/{{comboId}}/availability",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "combos",
                "{{comboId}}",
                "availability"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Criar Pedido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Cliente Teste\",\n  \"customerPhone\": \"11999990000\",\n  \"notes\": \"pedido criado pela collection\",\n  \"items\": [\n    {\n      \"menuItemId\": \"{{menuItemId}}\",\n      \"quantity\": 1,\n      \"addons\": []\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            }
          }
        },
        {
          "name": "Listar Pedidos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            }
          }
        },
        {
          "name": "Listar Pedidos por Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders?status=PENDING",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            }
          }
        },
        {
          "name": "Detalhe de Pedido",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders",
                "{{orderId}}"
              ]
            }
          }
        },
        {
          "name": "Atualizar Status do Pedido",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\",\n  \"reason\": \"Atualizado pela collection\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders",
                "{{orderId}}",
                "status"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Addons",
      "item": [
        {
          "name": "Listar Addons",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/addons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "addons"
              ]
            }
          }
        },
        {
          "name": "Listar Addons por Item",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/menu/{{menuItemId}}/addons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu",
                "{{menuItemId}}",
                "addons"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Swagger",
      "item": [
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/docs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "docs"
              ]
            }
          }
        },
        {
          "name": "Swagger JSON",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/docs/json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "docs",
                "json"
              ]
            }
          }
        }
      ]
    }
  ]
}
