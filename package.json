{
  "name": "sistema-pedidos-off-grid",
  "version": "1.0.0",
  "description": "Sistema de Pedidos 100% Offline com Rede Local",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/frontend",
    "packages/shared"
  ],
  "scripts": {
    "dev": "pnpm --filter=./apps/server dev & pnpm --filter=./apps/frontend dev",
    "build": "pnpm --filter=./apps/server build && pnpm --filter=./apps/frontend build",
    "start": "pnpm --filter=./apps/server start",
    "type-check": "pnpm --filter=./apps/server type-check && pnpm --filter=./apps/frontend type-check",
    "lint": "pnpm --filter=./apps/server lint && pnpm --filter=./apps/frontend lint"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
